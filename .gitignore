# ─── Go ───────────────────────────────────────────────────────────────────────
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work.sum

# Dependency directories
# vendor/

# ─── Terraform ────────────────────────────────────────────────────────────────
# Local state files — never commit these
*.tfstate
*.tfstate.backup

# Terraform working directory
**/.terraform/
.terraform.lock.hcl

# Terraform variable files that may contain secrets
*.tfvars
!*.tfvars.example

# Terraform plan output
*.tfplan

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE & Editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
